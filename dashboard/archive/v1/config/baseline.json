{
  "_comment": "HTT Brands deny-by-default security baseline. Audit scripts compare current state against these targets.",

  "crossTenantAccessDefaults": {
    "b2bCollaborationInbound": { "usersAndGroups": { "accessType": "blocked" }, "applications": { "accessType": "blocked" } },
    "b2bCollaborationOutbound": { "usersAndGroups": { "accessType": "blocked" }, "applications": { "accessType": "blocked" } },
    "b2bDirectConnectInbound": { "usersAndGroups": { "accessType": "blocked" }, "applications": { "accessType": "blocked" } },
    "b2bDirectConnectOutbound": { "usersAndGroups": { "accessType": "blocked" }, "applications": { "accessType": "blocked" } },
    "inboundTrust": { "isMfaAccepted": false, "isCompliantDeviceAccepted": false, "isHybridAzureADJoinedDeviceAccepted": false }
  },

  "crossTenantPartnerOverrides": {
    "_comment": "Applied per MTO partner tenant",
    "b2bCollaborationInbound": { "usersAndGroups": { "accessType": "allowed", "targets": [{"target":"AllUsers","targetType":"user"}] }, "applications": { "accessType": "allowed", "targets": [{"target":"AllApplications","targetType":"application"}] } },
    "b2bCollaborationOutbound": { "usersAndGroups": { "accessType": "allowed", "targets": [{"target":"AllUsers","targetType":"user"}] }, "applications": { "accessType": "allowed", "targets": [{"target":"AllApplications","targetType":"application"}] } },
    "b2bDirectConnectInbound": { "usersAndGroups": { "accessType": "allowed", "targets": [{"target":"AllUsers","targetType":"user"}] }, "applications": { "accessType": "allowed", "targets": [{"target":"Office365","targetType":"application"}] } },
    "b2bDirectConnectOutbound": { "usersAndGroups": { "accessType": "allowed", "targets": [{"target":"AllUsers","targetType":"user"}] }, "applications": { "accessType": "allowed", "targets": [{"target":"Office365","targetType":"application"}] } },
    "inboundTrust": { "isMfaAccepted": true, "isCompliantDeviceAccepted": true, "isHybridAzureADJoinedDeviceAccepted": true },
    "automaticUserConsentSettings": { "inboundAllowed": true, "outboundAllowed": true },
    "identitySynchronization": { "userSyncInbound": { "isSyncAllowed": true } }
  },

  "authorizationPolicy": {
    "allowInvitesFrom": "adminsAndGuestInviters",
    "guestUserRoleId": "2af84b1e-32c8-444d-8dfa-801d234f85e3",
    "guestUserRoleDescription": "Restricted Guest User",
    "allowEmailVerifiedUsersToJoinOrganization": false
  },

  "teamsFederation": {
    "allowFederatedUsers": true,
    "allowTeamsConsumer": false,
    "allowTeamsConsumerInbound": false,
    "federationMode": "AllowList",
    "allowedDomains": ["httbrands.com","bishopsbs.com","thelashlounge.com","frenchiesnails.com","deltacrown.com"]
  },

  "crossTenantSyncUserType": {
    "mappingType": "Constant",
    "value": "Member",
    "rationale": "HTT corporate users synced to brand tenants should be Members for full M365 access"
  },

  "staleGuestThresholdDays": 90,
  "accessReviewFrequency": "quarterly"
}
