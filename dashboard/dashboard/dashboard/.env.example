# ============================================================================
# CTU (Cross-Tenant Utility) — Environment Variables
# ============================================================================
#
# Copy this file to `.env` and fill in your actual values.
# NEVER commit `.env` to source control — it contains secrets.
#
#   cp .env.example .env
#
# ============================================================================

# ----------------------------------------------------------------------------
# CTU Service Principal Authentication
# ----------------------------------------------------------------------------
# App registration for the CTU-Governance-Engine service principal.
# Tyler provisions this SP and provides the client ID + cert thumbprint.
# Auth uses certificate-based app-only tokens (no interactive login).

CTU_CLIENT_ID="<your-app-client-id>"
CTU_CERT_THUMBPRINT="<your-certificate-thumbprint>"

# Optional: path to the .pfx certificate file (if not installed in cert store)
# CTU_CERT_PATH="/path/to/ctu-governance-engine.pfx"

# ----------------------------------------------------------------------------
# Tenant IDs
# ----------------------------------------------------------------------------
# All 5 tenants in the HTT Brands multi-tenant organization.
# These values are fixed — do not change unless tenants are restructured.

CTU_HTT_TENANT_ID="0c0e35dc-188a-4eb3-b8ba-61752154b407"
CTU_BCC_TENANT_ID="b5380912-79ec-452d-a6ca-6d897b19b294"
CTU_FN_TENANT_ID="98723287-044b-4bbb-9294-19857d4128a0"
CTU_TLL_TENANT_ID="3c7d2bf3-b597-4766-b5cb-2b489c2904d6"
CTU_DCE_TENANT_ID="ce62e17d-2feb-4e67-a115-8ea4af68da30"

# ----------------------------------------------------------------------------
# Admin Accounts
# ----------------------------------------------------------------------------
# Used for audit logging, notifications, and interactive auth fallback.
# These are NOT used for automated operations — the SP handles that.

CTU_PRIMARY_ADMIN="tyler.granlund-admin@httbrands.com"
CTU_SECONDARY_ADMIN="dustin.boyd-admin@httbrands.com"

# ----------------------------------------------------------------------------
# Runtime Configuration
# ----------------------------------------------------------------------------

# Log verbosity: Debug, Info, Warning, Error
CTU_LOG_LEVEL="Info"

# Dry-run mode: "true" = WhatIf (no changes), "false" = live execution
# Default to "true" for safety — only set to "false" when you mean it.
CTU_DRY_RUN="true"

# Output directory for audit reports and snapshots (relative to repo root)
CTU_OUTPUT_DIR="reports"

# ----------------------------------------------------------------------------
# Optional: Azure Monitor / Log Analytics (Phase 5)
# ----------------------------------------------------------------------------
# Required for deploying KQL alert queries to Azure Monitor.

# CTU_LOG_ANALYTICS_WORKSPACE_ID="<your-workspace-id>"
# CTU_LOG_ANALYTICS_RESOURCE_GROUP="<your-resource-group>"
# CTU_LOG_ANALYTICS_SUBSCRIPTION_ID="<your-azure-subscription-id>"

# ----------------------------------------------------------------------------
# Optional: Notification Channels
# ----------------------------------------------------------------------------
# Webhook URLs for alert notifications (Phase 5 monitoring).

# CTU_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
# CTU_TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."
